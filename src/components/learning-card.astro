---
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import { formatDate } from '@/lib/utils'
import { getSlug, getType, getLinkedBlogPost } from '@/lib/learning-utils'
import { Icon } from 'astro-icon/components'
import Link from './link.astro'
import type { LearningEntry } from '@/lib/learning-utils'

interface Props {
  entry: LearningEntry
}

const { entry } = Astro.props
const slug = getSlug(entry.id)
const type = getType(entry.id)
const formattedStart = formatDate(entry.data.start_date)
const formattedEnd = entry.data.end_date
  ? formatDate(entry.data.end_date)
  : null
const blogPost = await getLinkedBlogPost(slug)
---

<div class="hover:bg-muted/50 rounded-xl border p-4 transition-colors duration-300 ease-in-out">
  <Link
    href={`/learning/${type}/${slug}`}
    class="flex flex-col gap-3"
  >
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-lg font-medium">{entry.data.name}</h3>
      <Badge
        variant={
          entry.data.status === 'completed'
            ? 'default'
            : entry.data.status === 'in-progress'
              ? 'muted'
              : 'outline'
        }
      >
        {entry.data.status}
      </Badge>
    </div>

    <div class="text-muted-foreground flex flex-wrap items-center gap-x-2 text-xs">
      <span>{type}</span>
      <Separator orientation="vertical" className="h-4!" />
      <span>
        {formattedStart}{formattedEnd ? ` — ${formattedEnd}` : ' — Present'}
      </span>
    </div>

    <div class="flex flex-wrap gap-2">
      {entry.data.labels.map((label) => (
        <Badge variant="muted" className="flex items-center gap-x-1">
          <Icon name="lucide:hash" class="size-3" />
          {label}
        </Badge>
      ))}
    </div>

    {blogPost && (
      <div class="text-muted-foreground mt-1 flex items-center gap-1 text-xs">
        <Icon name="lucide:file-text" class="size-3" />
        <span>Blog post available</span>
      </div>
    )}
  </Link>
</div>
