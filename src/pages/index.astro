---
import BlogCard from '@/components/blog-card.astro'
import LearningCard from '@/components/learning-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import TerminalIntro from '@/components/terminal-intro.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import { getLearningWithPosts } from '@/lib/learning-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const allLearning = await getLearningWithPosts()
const learning = allLearning.slice(0, SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <TerminalIntro
    lines={[
      "Hi, I'm Jayesh.",
      "I write about software, math, and the things I'm learning.",
      "This is my digital garden: part blog, part project showcase and part notebook.",
    ]}
  />
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Recent posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See all posts <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Recent learning</h2>
    <ul class="flex flex-col gap-y-4">
      {
        learning.map((entry) => (
          <li>
            <LearningCard entry={entry} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/learning"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See all learning <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
