---
import LearningCard from '@/components/learning-card.astro'
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import PaginationComponent from '@/components/ui/pagination'
import Layout from '@/layouts/layout.astro'
import { Badge } from '@/components/ui/badge'
import { Icon } from 'astro-icon/components'
import { render } from 'astro:content'
import {
  getAllLearning,
  getLearningWithPosts,
  getSlug,
  filterByType,
  getLinkedBlogPost,
  getNotesUrl,
  getLearningPost,
  hasLearningPost,
} from '@/lib/learning-utils'
import { formatDate } from '@/lib/utils'
import type { LearningEntry } from '@/lib/learning-utils'

export async function getStaticPaths() {
  const pageSize = 5
  const allEntries = await getAllLearning()
  const courses = allEntries.filter((e) => e.id.startsWith('courses/'))
  const paths: any[] = []

  for (const entry of courses) {
    const slug = getSlug(entry.id)
    if (await hasLearningPost(slug)) {
      paths.push({
        params: { slug },
        props: { mode: 'detail', entry },
      })
    }
  }

  const withPosts = await getLearningWithPosts()
  const filtered = filterByType(withPosts, 'courses')
  const lastPage = Math.ceil(filtered.length / pageSize) || 1
  for (let i = 0; i < filtered.length; i += pageSize) {
    const pageNum = Math.floor(i / pageSize) + 1
    paths.push({
      params: { slug: pageNum === 1 ? undefined : String(pageNum) },
      props: {
        mode: 'list',
        entries: filtered.slice(i, i + pageSize),
        currentPage: pageNum,
        lastPage,
      },
    })
  }

  return paths
}

const { mode, entry, entries, currentPage, lastPage } = Astro.props

const allEntries = await getLearningWithPosts()
const allCourses = filterByType(allEntries, 'courses')
const allPapers = filterByType(allEntries, 'paper-readings')

let d: any = null
let blogPost: any = null
let notesUrl: string | null = null
let learningContent: any = null

if (mode === 'detail' && entry) {
  const slug = getSlug(entry.id)
  d = entry.data
  blogPost = await getLinkedBlogPost(slug)
  notesUrl = getNotesUrl(slug)
  const lp = await getLearningPost(slug)
  learningContent = lp ? await render(lp) : null
}

const startDate = d?.start_date ?? d?.event_log?.find((e: any) => e.type === 'start')?.date
---

{
  mode === 'detail' && entry ? (
    <Layout>
      <PageHead slot="head" title={d.name} description={d.name} />
      <section class="grid grid-cols-[minmax(0px,1fr)_min(calc(var(--breakpoint-md)-2rem),100%)_minmax(0px,1fr)] gap-y-6">
        <div class="col-start-2 flex flex-col gap-y-6">
          <Breadcrumbs
            items={[
              { href: '/learning', label: 'Learning', icon: 'lucide:graduation-cap' },
              { href: '/learning/courses', label: 'Courses', icon: 'lucide:book-open' },
              { label: d.name, icon: 'lucide:book-open-text' },
            ]}
          />
          <div class="flex flex-col gap-3">
            <div class="flex items-start justify-between gap-4">
              <h1 class="scroll-mt-31 text-3xl leading-tight font-medium sm:text-4xl">{d.name}</h1>
              <Badge
                variant={
                  d.status === 'completed'
                    ? 'default'
                    : d.status === 'in-progress'
                      ? 'muted'
                      : 'outline'
                }
                className="shrink-0"
              >
                {d.status}
              </Badge>
            </div>
            <div class="text-muted-foreground flex flex-wrap items-center gap-x-2 text-xs sm:text-sm">
              <span>Course</span>
              <span>&middot;</span>
              <span>
                {startDate ? formatDate(startDate) : ''}
                {d.end_date ? ` — ${formatDate(d.end_date)}` : startDate ? ' — Present' : ''}
              </span>
              {d.last_revision_date && (
                <>
                  <span>&middot;</span>
                  <span>Revised: {formatDate(d.last_revision_date)}</span>
                </>
              )}
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            {d.labels.map((label: string) => (
              <Badge variant="muted" className="flex items-center gap-x-1">
                <Icon name="lucide:hash" class="size-3" />
                {label}
              </Badge>
            ))}
          </div>
          {d.context && (
            <div class="bg-muted/50 rounded-lg p-4 text-sm">
              <div class="text-muted-foreground flex flex-col gap-x-6 gap-y-2 sm:flex-row sm:flex-wrap">
                <span><span class="font-medium text-foreground">Mode: </span>{d.context.type}</span>
                {d.context.institution && (
                  <span><span class="font-medium text-foreground">Institution: </span>{d.context.institution}</span>
                )}
                {d.context.program && (
                  <span><span class="font-medium text-foreground">Program: </span>{d.context.program}</span>
                )}
                <span>
                  <span class="font-medium text-foreground">Credential earned: </span>
                  {d.context.credential_earned ? 'Yes' : 'No'}
                </span>
              </div>
            </div>
          )}
          {learningContent && (
            <article class="prose max-w-none">
              <learningContent.Content />
            </article>
          )}
          <div>
            <h2 class="mb-3 text-lg font-medium">Timeline</h2>
            <div class="space-y-3">
              {d.event_log
                .sort((a: any, b: any) => b.date.valueOf() - a.date.valueOf())
                .map((event: any) => (
                  <div class="flex gap-3 text-sm">
                    <span class="text-muted-foreground shrink-0 w-[8.5rem] text-xs">
                      {formatDate(event.date)}
                    </span>
                    <div>
                      <span class="font-medium capitalize">{event.type.replace(/_/g, ' ')}</span>
                      {event.description && (
                        <span class="text-muted-foreground ml-1">— {event.description}</span>
                      )}
                    </div>
                  </div>
                ))}
            </div>
          </div>
          <div>
            <h2 class="mb-3 text-lg font-medium">Resources</h2>
            <div class="flex flex-wrap gap-2">
              {d.links.map((link: any) => (
                link.url && (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-muted-foreground/20 hover:bg-muted inline-flex items-center gap-1.5 rounded-md border px-3 py-1.5 text-sm transition-colors"
                  >
                    <Icon name="lucide:external-link" class="size-3.5" />
                    {link.type}
                  </a>
                )
              ))}
            </div>
            <div class="mt-4 flex flex-wrap gap-3">
              {blogPost && (
                <a
                  href={`/blog/${blogPost.id}`}
                  class="border-muted-foreground/20 hover:bg-muted inline-flex items-center gap-1.5 rounded-md border px-3 py-1.5 text-sm transition-colors"
                >
                  <Icon name="lucide:file-text" class="size-3.5" />
                  Read my notes on this course
                </a>
              )}
              {notesUrl && (
                <a
                  href={notesUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border-muted-foreground/20 hover:bg-muted inline-flex items-center gap-1.5 rounded-md border px-3 py-1.5 text-sm transition-colors"
                >
                  <Icon name="lucide:github" class="size-3.5" />
                  View notes on GitHub
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    </Layout>
  ) : (
    <Layout class="max-w-3xl">
      <PageHead slot="head" title="Courses — Learning" />
      <Breadcrumbs
        items={[
          { href: '/learning', label: 'Learning', icon: 'lucide:graduation-cap' },
          { href: '/learning/courses', label: 'Courses', icon: 'lucide:book-open' },
        ]}
      />
      <section class="text-muted-foreground mb-6 text-sm leading-relaxed">
        <p>
          A curated collection of courses and papers I've studied, documenting my learning journey — what I studied, what I built, and what I learned along the way.
        </p>
      </section>
      <div class="mb-6 flex gap-2 border-b pb-2">
        <a href="/learning" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors">
          All ({allEntries.length})
        </a>
        <a href="/learning/courses" class="border-foreground border-b-2 font-medium inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors">
          <Icon name="lucide:book-open" class="size-4" />
          Courses ({allCourses.length})
        </a>
        <a href="/learning/papers" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors">
          <Icon name="lucide:file-text" class="size-4" />
          Papers ({allPapers.length})
        </a>
      </div>
      <div class="flex flex-col gap-y-4">
        {entries.length === 0 && (
          <p class="text-muted-foreground py-8 text-center text-sm">No courses recorded yet.</p>
        )}
        {entries.map((entry: LearningEntry) => (
          <LearningCard entry={entry} />
        ))}
      </div>
      <PaginationComponent currentPage={currentPage} totalPages={lastPage} baseUrl="/learning/courses/" client:load />
    </Layout>
  )
}
