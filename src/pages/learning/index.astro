---
import LearningCard from '@/components/learning-card.astro'
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getLearningWithPosts, filterByType } from '@/lib/learning-utils'
import { Icon } from 'astro-icon/components'

const allEntries = await getLearningWithPosts()
const courses = filterByType(allEntries, 'courses')
const papers = filterByType(allEntries, 'paper-readings')

const currentFilter = Astro.url.searchParams.get('type') ?? 'all'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Learning" />
  <Breadcrumbs
    items={[{ label: 'Learning', href: '/learning', icon: 'lucide:graduation-cap' }]}
  />

  <div class="mb-6 flex gap-2 border-b pb-2">
    <a
      href="/learning"
      class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors ${
        currentFilter === 'all'
          ? 'border-foreground border-b-2 font-medium'
          : 'text-muted-foreground hover:text-foreground'
      }`}
    >
      All ({allEntries.length})
    </a>
    <a
      href="/learning?type=courses"
      class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors ${
        currentFilter === 'courses'
          ? 'border-foreground border-b-2 font-medium'
          : 'text-muted-foreground hover:text-foreground'
      }`}
    >
      <Icon name="lucide:book-open" class="size-4" />
      Courses ({courses.length})
    </a>
    <a
      href="/learning?type=papers"
      class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors ${
        currentFilter === 'papers'
          ? 'border-foreground border-b-2 font-medium'
          : 'text-muted-foreground hover:text-foreground'
      }`}
    >
      <Icon name="lucide:file-text" class="size-4" />
      Papers ({papers.length})
    </a>
  </div>

  <div class="flex min-h-[calc(100vh-18rem)] flex-col gap-y-4">
    {currentFilter === 'courses' && courses.length === 0 && (
      <p class="text-muted-foreground py-8 text-center text-sm">
        No courses recorded yet.
      </p>
    )}
    {currentFilter === 'papers' && papers.length === 0 && (
      <p class="text-muted-foreground py-8 text-center text-sm">
        No paper readings recorded yet.
      </p>
    )}

    {currentFilter === 'all' &&
      allEntries.map((entry) => (
        <LearningCard entry={entry} />
      ))}
    {currentFilter === 'courses' &&
      courses.map((entry) => (
        <LearningCard entry={entry} />
      ))}
    {currentFilter === 'papers' &&
      papers.map((entry) => (
        <LearningCard entry={entry} />
      ))}
  </div>
</Layout>
